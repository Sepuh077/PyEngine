# Cython sources. Pre-generated *.c may be present when building an sdist
# after a local cythonize; build-system.requires includes Cython so .pyx alone
# is enough for wheel builds.
recursive-include engine/cython *.pyx *.pxd *.pxi *.c
recursive-include engine/d3/shaders *.vert *.frag *.glsl
include engine/py.typed
include engine/cython/py.typed

# Include the dedicated Cython build helper (for developers)
include setup_cython.py

# Core files for sdist
include README.md
include pyproject.toml
include setup.py
include requirements.txt
